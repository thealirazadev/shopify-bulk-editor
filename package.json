{
  "name": "shopify-bulk-editor",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.20.0"
  },
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "lint": "eslint . --report-unused-disable-directives",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "vitest run --config vitest.bench.config.ts",
    "start": "remix-serve ./build/server/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "overrides": {
    "tar": "7.5.21",
    "estree-util-value-to-estree": "3.5.0",
    "vite": "6.4.3",
    "esbuild": "0.25.12"
  },
  "dependencies": {
    "@prisma/client": "7.9.0",
    "@remix-run/node": "2.17.5",
    "@remix-run/react": "2.17.5",
    "@remix-run/serve": "2.17.5",
    "@shopify/app-bridge-react": "4.2.12",
    "@shopify/polaris": "13.9.5",
    "@shopify/shopify-app-remix": "4.2.1",
    "@shopify/shopify-app-session-storage-prisma": "9.0.1",
    "csv-parse": "7.0.1",
    "csv-stringify": "6.8.1",
    "isbot": "5.2.1",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@remix-run/dev": "2.17.5",
    "@shopify/eslint-plugin": "48.0.2",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "8.57.1",
    "prettier": "3.9.5",
    "prisma": "6.19.3",
    "typescript": "5.4.5",
    "vite": "6.4.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.7"
  }
}
