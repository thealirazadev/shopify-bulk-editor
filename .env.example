# Shopify app API key (Client ID) from the Partner Dashboard.
SHOPIFY_API_KEY=00000000000000000000000000000000

# Shopify app API secret (Client Secret) from the Partner Dashboard. Keep private.
SHOPIFY_API_SECRET=replace-with-your-shopify-api-secret

# Comma-separated access scopes the app requests during OAuth.
SCOPES=read_products,write_products

# Public HTTPS URL where the app is reachable (tunnel URL in dev, real domain in prod).
SHOPIFY_APP_URL=https://example-tunnel.trycloudflare.com

# Prisma database connection string. SQLite file in dev; Postgres/MySQL URL in prod.
DATABASE_URL=file:./dev.sqlite
